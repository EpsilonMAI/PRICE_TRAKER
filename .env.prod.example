CADDY_SITE_ADDRESS=your-domain.example

SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.example,www.your-domain.example
CORS_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example,https://www.your-domain.example

DB_NAME=price_tracker
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=db
DB_PORT=5432

# Email / SMTP
# Для реальной отправки на сервере нужен SMTP backend, иначе письма попадут только в логи.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@example.com
